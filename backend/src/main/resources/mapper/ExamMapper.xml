<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cantonfair.exam.mapper.ExamMapper">

    <resultMap id="BaseResultMap" type="com.cantonfair.exam.entity.Exam">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="paper_id" property="paperId"/>
        <result column="paper_name" property="paperName"/>
        <result column="creator_id" property="creatorId"/>
        <result column="creator_name" property="creatorName"/>
        <result column="department_id" property="departmentId"/>
        <result column="department_name" property="departmentName"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="duration" property="duration"/>
        <result column="total_score" property="totalScore"/>
        <result column="description" property="description"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, paper_id, paper_name, creator_id, creator_name, department_id, department_name,
        start_time, end_time, duration, total_score, description, status, create_time, update_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from exam
        where id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from exam
        order by create_time desc
    </select>

    <select id="selectByCondition" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from exam
        <where>
            <if test="name != null and name != ''">
                and name like concat('%', #{name}, '%')
            </if>
            <if test="creatorId != null">
                and creator_id = #{creatorId}
            </if>
            <if test="departmentId != null">
                and department_id = #{departmentId}
            </if>
            <if test="status != null">
                and status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectByCreatorId" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from exam
        where creator_id = #{creatorId}
        order by start_time desc
    </select>

    <select id="selectAvailableExams" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from exam
        order by start_time desc
    </select>

    <select id="selectByDepartmentId" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from exam
        where department_id = #{departmentId}
        order by start_time desc
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into exam(name, paper_id, paper_name, creator_id, creator_name, department_id, department_name,
        start_time, end_time, duration, total_score, description, status)
        values(#{name}, #{paperId}, #{paperName}, #{creatorId}, #{creatorName}, #{departmentId}, #{departmentName},
        #{startTime}, #{endTime}, #{duration}, #{totalScore}, #{description}, #{status})
    </insert>

    <update id="update">
        update exam
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="paperId != null">paper_id = #{paperId},</if>
            <if test="paperName != null">paper_name = #{paperName},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="duration != null">duration = #{duration},</if>
            <if test="totalScore != null">total_score = #{totalScore},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById">
        delete from exam where id = #{id}
    </delete>

    <delete id="deleteBatch">
        delete from exam where id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>