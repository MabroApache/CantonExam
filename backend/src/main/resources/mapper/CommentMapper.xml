<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cantonfair.exam.mapper.CommentMapper">

    <resultMap id="BaseResultMap" type="com.cantonfair.exam.entity.Comment">
        <id column="id" property="id"/>
        <result column="share_id" property="shareId"/>
        <result column="student_id" property="studentId"/>
        <result column="student_name" property="studentName"/>
        <result column="content" property="content"/>
        <result column="parent_id" property="parentId"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        cm.id, cm.share_id, cm.student_id, cm.content, cm.parent_id, cm.status, cm.create_time, cm.update_time,
        s.name as student_name
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from comment cm
        left join student s on cm.student_id = s.id
        where cm.id = #{id}
    </select>

    <select id="selectByShareId" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from comment cm
        left join student s on cm.student_id = s.id
        where cm.share_id = #{shareId}
        order by cm.create_time desc
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into comment(share_id, student_id, content, parent_id, status)
        values(#{shareId}, #{studentId}, #{content}, #{parentId}, #{status})
    </insert>

    <delete id="deleteById">
        delete from comment where id = #{id}
    </delete>

    <delete id="deleteByShareId">
        delete from comment where share_id = #{shareId}
    </delete>

</mapper>