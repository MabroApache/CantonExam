<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cantonfair.exam.mapper.PaperQuestionMapper">

    <resultMap id="BaseResultMap" type="com.cantonfair.exam.entity.PaperQuestion">
        <id column="id" property="id"/>
        <result column="paper_id" property="paperId"/>
        <result column="question_id" property="questionId"/>
        <result column="score" property="score"/>
        <result column="sort" property="sort"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, paper_id, question_id, score, sort, create_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from paper_question
        where id = #{id}
    </select>

    <select id="selectByPaperId" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from paper_question
        where paper_id = #{paperId}
        order by sort asc
    </select>

    <select id="selectByQuestionId" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from paper_question
        where question_id = #{questionId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into paper_question(paper_id, question_id, score, sort)
        values(#{paperId}, #{questionId}, #{score}, #{sort})
    </insert>

    <insert id="insertBatch">
        insert into paper_question(paper_id, question_id, score, sort)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.paperId}, #{item.questionId}, #{item.score}, #{item.sort})
        </foreach>
    </insert>

    <delete id="deleteByPaperId">
        delete from paper_question where paper_id = #{paperId}
    </delete>

    <delete id="deleteById">
        delete from paper_question where id = #{id}
    </delete>

</mapper>